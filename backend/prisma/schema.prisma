generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPERADMIN
  CUSTOMER
  STAFF
  ADMIN
}

enum GoldAdvanceStatus {
  ACTIVE
  CLOSED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  PROFIT
  REFERRAL
  STAFF_COMMISSION
  PROMOTIONAL_CREDIT
  GOLD_ADVANCE // Legacy mapping
  DAILY_RETURN // Legacy mapping
  REFERRAL_REWARD // Legacy mapping
}

enum OrderStatus {
  PENDING
  PAID
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalSource {
  BALANCE
  GOLD_ADVANCE
  PROFIT
  REFERRAL
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditAction {
  CUSTOMER_CREATED
  GOLD_ADVANCE_DEPOSITED
  GOLD_ADVANCE_WITHDRAWN
  ORDER_PURCHASED
  ORDER_READY
  ORDER_DELIVERED
  STAFF_ASSIGNED
  STAFF_REASSIGNED
  CUSTOMER_UPDATED
  WITHDRAWAL_REQUEST_CREATED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  STAFF_CREATED
  REFERRAL_LINKED
  PROFIT_DISTRIBUTED
  WALLET_ADJUSTED
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(CUSTOMER)
  inviteCode   String?  @unique
  
  // Professional / Identity Details
  contactNo    String?  @unique
  mobile       String?  @unique // For legacy compatibility
  aadharNo     String?
  aadhar       String?  // For legacy compatibility
  pan          String?
  address      String?
  photo        String?
  gender       String?
  dob          DateTime?
  
  initialGoldAdvanceAmount Decimal? @db.Decimal(15, 2)
  
  referredBy   String?
  staffId      String?
  
  wallet        Wallet?
  goldAdvances  GoldAdvance[]
  transactions Transaction[]
  withdrawals  WithdrawalRequest[]
  orders       Order[]
  performedTransactions Transaction[] @relation("PerformedTransactions")
  commissions     StaffCommission[] @relation("StaffCommissions")
  paidCommissions StaffCommission[] @relation("CustomerCommissions")
  
  // Relations
  referrer     User?    @relation("ReferrerRelation", fields: [referredBy], references: [id])
  referrals    User[]   @relation("ReferrerRelation")
  assignedStaff User?   @relation("StaffRelation", fields: [staffId], references: [id])
  customers     User[]   @relation("StaffRelation")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([staffId])
  @@index([role])
  @@index([email])
}

// ─── Wallet ──────────────────────────────────────────────────────────────────

model Wallet {
  id                     String  @id @default(cuid())
  userId                 String  @unique
  user                   User    @relation(fields: [userId], references: [id])
  goldAdvanceAmount      Decimal @default(0) @db.Decimal(15, 2)
  profitAmount           Decimal @default(0) @db.Decimal(15, 2)
  referralAmount         Decimal @default(0) @db.Decimal(15, 2)
  promotionalAmount      Decimal @default(0) @db.Decimal(15, 2)
  totalWithdrawable      Decimal @default(0) @db.Decimal(15, 2)
  
  // Legacy fields (optional migration path)
  balance                Decimal @default(0) @db.Decimal(15, 2)
  dailyReturnBalance     Decimal @default(0) @db.Decimal(15, 2)
  referralBalance        Decimal @default(0) @db.Decimal(15, 2)
  staffCommissionBalance Decimal @default(0) @db.Decimal(15, 2)
}

// ─── Gold Advance ─────────────────────────────────────────────────────────────

model GoldAdvance {
  id            String           @id @default(cuid())
  invoiceNo     Int              @unique @default(autoincrement())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  advanceAmount Decimal          @db.Decimal(15, 2)
  startDate     DateTime         @default(now())
  status        GoldAdvanceStatus @default(ACTIVE)
  description   String?
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([status])
}

// ─── Transaction ─────────────────────────────────────────────────────────────

model Transaction {
  id          String          @id @default(cuid())
  entityId    String?         // Reference to GoldAdvance or WithdrawalRequest ID
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Decimal         @db.Decimal(15, 2)
  balanceAfter Decimal        @default(0) @db.Decimal(15, 2)
  description String?
  
  performedById String?
  performedBy   User?          @relation("PerformedTransactions", fields: [performedById], references: [id])
  
  createdAt   DateTime        @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ─── WithdrawalRequest ───────────────────────────────────────────────────────

model WithdrawalRequest {
  id        String           @id @default(cuid())
  invoiceNo Int              @unique @default(autoincrement())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  amount    Decimal          @db.Decimal(15, 2)
  source    WithdrawalSource @default(PROFIT)
  status    WithdrawalStatus @default(PENDING)
  description String?
  
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@index([status])
}

// ─── AuditLog ───────────────────────────────────────────────────────────────

model AuditLog {
  id                String   @id @default(cuid())
  actionType        AuditAction
  entityType        String
  entityId          String
  performedByUserId String?
  performedByRole   Role?
  description       String?
  previousData      Json?
  newData           Json?
  comment           String?
  ipAddress         String?
  createdAt         DateTime @default(now())
}

// ─── Referral ────────────────────────────────────────────────────────────────

model Referral {
  id             String @id @default(cuid())
  referrerId     String
  referredUserId String
}

// ─── StaffCommission ────────────────────────────────────────────────────────

model StaffCommission {
  id         String   @id @default(cuid())
  staffId    String
  staff      User     @relation("StaffCommissions", fields: [staffId], references: [id])
  customerId String
  customer   User     @relation("CustomerCommissions", fields: [customerId], references: [id])
  amount     Decimal  @db.Decimal(15, 2)
  
  createdAt  DateTime @default(now())

  @@index([staffId])
  @@index([customerId])
}

// ─── DailyProfitLog (System Log) ─────────────────────────────────────────────

model DailyProfitLog {
  id               String   @id @default(uuid())
  date             String   @unique
  status           String   // PROCESSING | SUCCESS | FAILED
  processed        Int      @default(0)
  totalDistributed Decimal  @default(0) @db.Decimal(15, 2)
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SystemSetting {
  id                        String  @id @default("default")
  goldMode                  String  @default("DIGITAL") // "DIGITAL" or "PHYSICAL"
  showGST                   Boolean @default(true)
  gstPercentage             Decimal @default(18.0) @db.Decimal(5, 2)
  
  // Profit Configuration
  monthlyProfitPercentage   Decimal @default(5.0) @db.Decimal(5, 2)
  monthlyReferralPercentage Decimal @default(5.0) @db.Decimal(5, 2)
  monthlyStaffPercentage    Decimal @default(5.0) @db.Decimal(5, 2)
  
  // Feature Flags
  showAdvancedSettings      Boolean @default(false)
  
  updatedAt                 DateTime @updatedAt
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  isEnabled   Boolean  @default(false)
  category    String   @default("FEATURE") // ROLE, FEATURE, NOTIFICATION, CUSTOM
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  weight      Decimal  @db.Decimal(10, 3)
  purity      String   @default("24K")
  imageUrl    String?
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]
}

model GoldPrice {
  id        String   @id @default(cuid())
  buyPrice  Decimal  @db.Decimal(15, 2)
  sellPrice Decimal  @db.Decimal(15, 2)
  timestamp DateTime @default(now())

  @@index([timestamp])
}

model Order {
  id                   String        @id @default(cuid())
  invoiceNo            Int           @unique @default(autoincrement())
  userId               String
  user                 User          @relation(fields: [userId], references: [id])
  productId            String
  product              Product       @relation(fields: [productId], references: [id])
  quantity             Int
  amount               Decimal       @db.Decimal(15, 2)
  gst                  Decimal       @db.Decimal(15, 2)
  total                Decimal       @db.Decimal(15, 2)
  status               OrderStatus   @default(PENDING)
  paymentStatus        PaymentStatus @default(PENDING)
  paymentId            String?
  razorpayPaymentId    String?
  razorpaySignature    String?
  paidAt               DateTime?
  expectedDeliveryDate DateTime?
  readyAt              DateTime?
  deliveredAt          DateTime?
  readyMarkedById      String?
  tokenNumber          String?       // Assigned when admin marks READY — for office pickup
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([paymentStatus])
}
