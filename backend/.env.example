# Royal Gold Traders — Backend Environment Variables
# Copy this file to .env and fill in your credentials

# ── Database ──────────────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://your_db_user:your_db_password@your.hostinger.host:3306/rgt_db"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret-key-here"
JWT_EXPIRES_IN="7d"
SMS_API_KEY="replace-with-your-2factor-api-key"

# ── Payments (Optional: required only if using order/payment flow) ──────────
RAZORPAY_KEY_ID="rzp_live_or_test_key_id"
RAZORPAY_KEY_SECRET="rzp_live_or_test_key_secret"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3001"
BACKEND_URL="http://localhost:4000"

# ── Cloudflare R2 Storage ────────────────────────────────────────────────────
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="replace-with-r2-access-key-id"
R2_SECRET_ACCESS_KEY="replace-with-r2-secret-access-key"
R2_BUCKET_NAME="rgt"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxx.r2.dev"
